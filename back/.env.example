# HTTP port (default: 3001)
PORT=4000

# Allowed browser origins for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Secret for signed cookies (cookie-parser). Leave empty to disable signing.
COOKIE_SECRET=cookie-secret

# res.cookie() defaults (optional)
COOKIE_HTTP_ONLY=true   # true | false
COOKIE_SAME_SITE=lax    # strict | lax | none
COOKIE_SECURE=false     # true | false

# unset = true if NODE_ENV=production, else false; or set true/false explicitly
COOKIE_PATH=/
COOKIE_MAX_AGE_MS=7*(24*60*60*1000)
# milliseconds (default 7 days)

# Set to production in deploy so secure cookies and similar flags apply.
NODE_ENV=development # development / production

# Prisma (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"
# npx prisma migrate dev
# npx prisma db seed   # demo user demo@example.com / demo