{
  "name": "next-express-starter",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "postinstall": "pnpm --filter back run prisma:generate",
    "dev": "concurrently -k -n back,front -c blue,cyan \"pnpm --filter back run dev\" \"pnpm --filter web run dev\"",
    "build": "pnpm --filter web run build",
    "lint": "pnpm --filter web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
